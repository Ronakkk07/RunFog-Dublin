# .ebextensions/db-migrate.config
#
# Migrations are handled inside the Docker container via startup.sh.
# This file exists only to document that fact.
#
# container_commands do NOT work on the Docker platform — they run before
# the container starts and cannot access the Python environment inside it.

option_settings:
  aws:elasticbeanstalk:application:
    Application Healthcheck URL: /health/