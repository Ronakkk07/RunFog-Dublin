# .ebextensions/django.config
#
# These option_settings apply to the Docker platform.
# Do NOT add WSGIPath here — that is only for the native Python platform.
# Gunicorn is already configured in the Dockerfile CMD.

option_settings:
  aws:elasticbeanstalk:application:environment:
    DJANGO_DEBUG: "False"
    APP_TIME_ZONE: "Europe/Dublin"
    AWS_REGION: "us-east-1"
    RUNNERHUB_QUEUE_BACKEND: "sqs"
    RUNNERHUB_SQS_QUEUE_URL: "https://sqs.us-east-1.amazonaws.com/833090513675/runfog-batches"
    RUNNERHUB_FRONTEND_POLL_SECONDS: "15"

  aws:elasticbeanstalk:application:
    Application Healthcheck URL: /health/
